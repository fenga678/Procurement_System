<Window x:Class="CanteenProcurement.Wpf.Dialogs.TaskEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="新建任务"
        Width="{DynamicResource DialogWidth.Medium}"
        SizeToContent="Height"

        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Style="{StaticResource AppWindowStyle}">
    <Border Style="{StaticResource CardStyle}" Margin="20">
        <StackPanel>
            <TextBlock Text="新建采购任务" Style="{StaticResource DialogTitleStyle}" />
            <TextBlock Text="统一录入年月、预算与波动率，避免页面代码动态拼窗。" Style="{StaticResource DialogSubtitleStyle}" Margin="0,8,0,0" />

            <Grid Margin="0,18,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Label Grid.Row="0" Grid.Column="0" Content="年月 (YYYYMM)" />
                <TextBox x:Name="YearMonthText" Grid.Row="0" Grid.Column="1" Style="{StaticResource DefaultTextBoxStyle}" />

                <Label Grid.Row="1" Grid.Column="0" Content="总预算" Margin="0,12,0,0" />
                <TextBox x:Name="BudgetText" Grid.Row="1" Grid.Column="1" Style="{StaticResource DefaultTextBoxStyle}" Margin="0,12,0,0" />

                <Label Grid.Row="2" Grid.Column="0" Content="波动率 (0-1)" Margin="0,12,0,0" />
                <TextBox x:Name="FloatRateText" Grid.Row="2" Grid.Column="1" Style="{StaticResource DefaultTextBoxStyle}" Margin="0,12,0,0" />

                <Label Grid.Row="3" Grid.Column="0" Content="创建人" Margin="0,12,0,0" />
                <TextBox x:Name="CreatedByText" Grid.Row="3" Grid.Column="1" Style="{StaticResource DefaultTextBoxStyle}" Margin="0,12,0,0" />
            </Grid>

            <TextBlock x:Name="ValidationText" Foreground="{DynamicResource Brush.Danger}" Margin="0,14,0,0" Visibility="Collapsed" TextWrapping="Wrap" />

            <!-- 新增：分类金额配置区域 -->
            <Expander Header="高级设置：分类金额配置（可选）" Margin="0,16,0,0">
                <StackPanel x:Name="CategoryConfigPanel" Margin="8,8,0,0">
                    <TextBlock Text="留空则按比例自动分配；勾选'固定'并填写金额可指定该分类的精确预算"
                               FontSize="11" Foreground="Gray" Margin="0,0,0,8" TextWrapping="Wrap" />
                </StackPanel>
            </Expander>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="取消" Style="{StaticResource SecondaryButtonStyle}" Width="{DynamicResource ControlWidth.Medium}" Margin="0,0,8,0" Click="CancelButton_Click" />
                <Button Content="保存" Style="{StaticResource PrimaryButtonStyle}" Width="{DynamicResource ControlWidth.Medium}" Click="SaveButton_Click" />
            </StackPanel>

        </StackPanel>
    </Border>
</Window>
