<Window x:Class="CanteenProcurement.Wpf.Dialogs.CategoryEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="分类编辑"
        Width="440"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Style="{StaticResource AppWindowStyle}">
    <Border Style="{StaticResource CardStyle}" Margin="20">
        <StackPanel>
            <TextBlock x:Name="TitleText" Style="{StaticResource DialogTitleStyle}" />

            <Grid Margin="0,18,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Label Grid.Row="0" Grid.Column="0" Content="名称" />
                <TextBox x:Name="NameText" Grid.Row="0" Grid.Column="1" Style="{StaticResource DefaultTextBoxStyle}" />

                <Label Grid.Row="1" Grid.Column="0" Content="编码" Margin="0,12,0,0" />
                <TextBox x:Name="CodeText" Grid.Row="1" Grid.Column="1" Style="{StaticResource DefaultTextBoxStyle}" Margin="0,12,0,0" />

                <Label Grid.Row="2" Grid.Column="0" Content="预算占比 (0-1)" Margin="0,12,0,0" />
                <TextBox x:Name="RatioText" Grid.Row="2" Grid.Column="1" Style="{StaticResource DefaultTextBoxStyle}" Margin="0,12,0,0" />

                <Label Grid.Row="3" Grid.Column="0" Content="频率(天)" Margin="0,12,0,0" />
                <TextBox x:Name="FrequencyText" Grid.Row="3" Grid.Column="1" Style="{StaticResource DefaultTextBoxStyle}" Margin="0,12,0,0" />

                <Label Grid.Row="4" Grid.Column="0" Content="最小品类数" Margin="0,12,0,0" />
                <TextBox x:Name="MinItemsText" Grid.Row="4" Grid.Column="1" Style="{StaticResource DefaultTextBoxStyle}" Margin="0,12,0,0" />

                <Label Grid.Row="5" Grid.Column="0" Content="最大品类数" Margin="0,12,0,0" />
                <TextBox x:Name="MaxItemsText" Grid.Row="5" Grid.Column="1" Style="{StaticResource DefaultTextBoxStyle}" Margin="0,12,0,0" />

                <Label Grid.Row="6" Grid.Column="0" Content="排序" Margin="0,12,0,0" />
                <TextBox x:Name="SortText" Grid.Row="6" Grid.Column="1" Style="{StaticResource DefaultTextBoxStyle}" Margin="0,12,0,0" />

                <Label Grid.Row="7" Grid.Column="0" Content="状态" Margin="0,12,0,0" />
                <CheckBox x:Name="StatusCheck" Grid.Row="7" Grid.Column="1" Content="启用" Margin="0,18,0,0" />
            </Grid>

            <TextBlock x:Name="ValidationText" Foreground="{DynamicResource Brush.Danger}" Margin="0,14,0,0" Visibility="Collapsed" TextWrapping="Wrap" />

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="取消" Style="{StaticResource SecondaryButtonStyle}" Width="88" Margin="0,0,8,0" Click="CancelButton_Click" />
                <Button Content="保存" Style="{StaticResource PrimaryButtonStyle}" Width="88" Click="SaveButton_Click" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
