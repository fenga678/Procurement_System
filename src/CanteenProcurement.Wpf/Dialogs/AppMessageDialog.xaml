<Window x:Class="CanteenProcurement.Wpf.Dialogs.AppMessageDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="系统提示"
        Width="420"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Style="{StaticResource AppWindowStyle}">
    <Border Style="{StaticResource CardStyle}" Margin="20">
        <StackPanel>
            <TextBlock x:Name="TitleText" Style="{StaticResource DialogTitleStyle}" />
            <TextBlock x:Name="MessageText" Style="{StaticResource DialogSubtitleStyle}" Margin="0,12,0,0" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button x:Name="CancelButton" Content="取消" Style="{StaticResource SecondaryButtonStyle}" Width="88" Margin="0,0,8,0" Click="CancelButton_Click" Visibility="Collapsed" />
                <Button x:Name="ConfirmButton" Content="确定" Style="{StaticResource PrimaryButtonStyle}" Width="88" Click="ConfirmButton_Click" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
