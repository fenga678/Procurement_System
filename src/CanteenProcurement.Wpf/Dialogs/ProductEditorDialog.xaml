<Window x:Class="CanteenProcurement.Wpf.Dialogs.ProductEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="商品编辑"
        Width="460"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Style="{StaticResource AppWindowStyle}">
    <Border Style="{StaticResource CardStyle}" Margin="20">
        <StackPanel>
            <TextBlock x:Name="TitleText" Style="{StaticResource DialogTitleStyle}" />
            <Grid Margin="0,18,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Label Grid.Row="0" Grid.Column="0" Content="名称" />
                <TextBox x:Name="NameText" Grid.Row="0" Grid.Column="1" Style="{StaticResource DefaultTextBoxStyle}" />

                <Label Grid.Row="1" Grid.Column="0" Content="分类" Margin="0,12,0,0" />
                <ComboBox x:Name="CategoryCombo" Grid.Row="1" Grid.Column="1" Margin="0,12,0,0" DisplayMemberPath="Name" SelectedValuePath="Code" VerticalContentAlignment="Center"/>

                <Label Grid.Row="2" Grid.Column="0" Content="单价" Margin="0,12,0,0" />
                <TextBox x:Name="PriceText" Grid.Row="2" Grid.Column="1" Style="{StaticResource DefaultTextBoxStyle}" Margin="0,12,0,0" />

                <Label Grid.Row="3" Grid.Column="0" Content="单位" Margin="0,12,0,0" />
                <TextBox x:Name="UnitText" Grid.Row="3" Grid.Column="1" Style="{StaticResource DefaultTextBoxStyle}" Margin="0,12,0,0" />

                <Label Grid.Row="4" Grid.Column="0" Content="最小间隔(天)" Margin="0,12,0,0" />
                <TextBox x:Name="MinIntervalText" Grid.Row="4" Grid.Column="1" Style="{StaticResource DefaultTextBoxStyle}" Margin="0,12,0,0" />

                <Label Grid.Row="5" Grid.Column="0" Content="备注" Margin="0,12,0,0" />
                <TextBox x:Name="RemarkText" Grid.Row="5" Grid.Column="1" Style="{StaticResource DefaultTextBoxStyle}" Margin="0,12,0,0" Height="72" TextWrapping="Wrap" AcceptsReturn="True" VerticalContentAlignment="Top" />

                <Label Grid.Row="6" Grid.Column="0" Content="状态" Margin="0,12,0,0" />
                <CheckBox x:Name="StatusCheck" Grid.Row="6" Grid.Column="1" Content="启用" Margin="0,18,0,0" />
            </Grid>

            <TextBlock x:Name="ValidationText" Foreground="{DynamicResource Brush.Danger}" Margin="0,14,0,0" Visibility="Collapsed" TextWrapping="Wrap" />

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="取消" Style="{StaticResource SecondaryButtonStyle}" Width="88" Margin="0,0,8,0" Click="CancelButton_Click" />
                <Button Content="保存" Style="{StaticResource PrimaryButtonStyle}" Width="88" Click="SaveButton_Click" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
