<UserControl x:Class="CanteenProcurement.Wpf.Controls.LoadingOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Visibility="Collapsed">
    <Grid x:Name="OverlayRoot" Background="{DynamicResource Brush.Overlay}">
        <Border Width="320" HorizontalAlignment="Center" VerticalAlignment="Center" Style="{StaticResource CardStyle}">
            <StackPanel>
                <TextBlock Text="正在处理中" Style="{StaticResource DialogTitleStyle}" HorizontalAlignment="Center" />
                <TextBlock x:Name="MessageText" Text="请稍候..." Style="{StaticResource DialogSubtitleStyle}" HorizontalAlignment="Center" Margin="0,8,0,0" />
                <ProgressBar IsIndeterminate="True" Height="8" Margin="0,18,0,0" Foreground="{DynamicResource Brush.Primary}" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
