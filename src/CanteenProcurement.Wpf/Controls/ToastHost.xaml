<UserControl x:Class="CanteenProcurement.Wpf.Controls.ToastHost"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root"
             IsHitTestVisible="False">
    <ItemsControl ItemsSource="{Binding Notifications, ElementName=Root}">
        <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
                <StackPanel Orientation="Vertical" HorizontalAlignment="Right" />
            </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
            <DataTemplate>
                <Border Margin="0,0,0,10" Padding="14,12" CornerRadius="12" BorderThickness="1" MinWidth="280">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="{DynamicResource Brush.Info.Subtle}" />
                            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Info}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Tone}" Value="success">
                                    <Setter Property="Background" Value="{DynamicResource Brush.Success.Subtle}" />
                                    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Success}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Tone}" Value="warning">
                                    <Setter Property="Background" Value="{DynamicResource Brush.Warning.Subtle}" />
                                    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Warning}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Tone}" Value="error">
                                    <Setter Property="Background" Value="{DynamicResource Brush.Danger.Subtle}" />
                                    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Danger}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel>
                        <TextBlock Text="{Binding Title}" FontWeight="Bold" Foreground="{DynamicResource Brush.Text.Primary}" />
                        <TextBlock Text="{Binding Message}" Margin="0,4,0,0" Foreground="{DynamicResource Brush.Text.Secondary}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </DataTemplate>
        </ItemsControl.ItemTemplate>
    </ItemsControl>
</UserControl>
