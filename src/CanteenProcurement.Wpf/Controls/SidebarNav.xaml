<UserControl x:Class="CanteenProcurement.Wpf.Controls.SidebarNav"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <StackPanel>
            <TextBlock Text="运营导航" Style="{StaticResource HintTextStyle}" Foreground="{DynamicResource Brush.Secondary.Subtle}" Margin="0,0,0,12" />
            <Button x:Name="CategoryManagementButton" Content="分类管理" Style="{StaticResource NavigationButtonStyle}" Click="CategoryManagementButton_Click" />
            <Button x:Name="ProductManagementButton" Content="商品管理" Style="{StaticResource NavigationButtonStyle}" Click="ProductManagementButton_Click" />
            <Button x:Name="TaskManagementButton" Content="任务管理" Style="{StaticResource NavigationButtonStyle}" Click="TaskManagementButton_Click" />
            <Button x:Name="SettingsButton" Content="系统设置" Style="{StaticResource NavigationButtonStyle}" Click="SettingsButton_Click" />
        </StackPanel>
    </Grid>
</UserControl>
