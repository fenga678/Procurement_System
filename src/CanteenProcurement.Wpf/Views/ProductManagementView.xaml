<UserControl x:Class="CanteenProcurement.Wpf.Views.ProductManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:CanteenProcurement.Wpf.Controls"


             mc:Ignorable="d"
             d:DesignHeight="720"
             d:DesignWidth="1100"
             Background="{DynamicResource Brush.Background}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource PageHeaderCardStyle}" Margin="0,0,0,12" Padding="16,10">
            <Grid>
                <!-- 定义 3 列：左 中 右 -->
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <!-- 左：标题 -->
                    <ColumnDefinition Width="*" />
                    <!-- 中：统计文字（居中） -->
                    <ColumnDefinition Width="Auto" />
                    <!-- 右：搜索框 -->
                </Grid.ColumnDefinitions>

                <!-- 左侧：标题 -->
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="商品管理" Style="{StaticResource PageTitleStyle}" Foreground="{DynamicResource Brush.Text.Inverse}" FontSize="18" />
                </StackPanel>

                <!-- 中间：统计文字 —— 完美居中，不重叠 -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock VerticalAlignment="Center" FontSize="12" Foreground="{DynamicResource Brush.Text.Inverse}" Opacity="0.7" Margin="0">启用</TextBlock>
                    <TextBlock Tag="Product.StatsCount" VerticalAlignment="Center" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource Brush.Text.Inverse}" Margin="4,0,4,0" />
                    <TextBlock VerticalAlignment="Center" FontSize="12" Foreground="{DynamicResource Brush.Text.Inverse}" Opacity="0.7">/</TextBlock>
                    <TextBlock Tag="Product.StatsTotal" VerticalAlignment="Center" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource Brush.Text.Inverse}" Margin="4,0,0,0" />
                </StackPanel>

                <!-- 右侧：搜索 + 筛选 -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <TextBox Tag="Product.SearchBox" Style="{StaticResource DefaultTextBoxStyle}" Width="140" VerticalAlignment="Center"
                     ToolTip="搜索商品名称" TextChanged="SearchBox_TextChanged" />
                    <ComboBox Tag="Product.CategoryFilter" Width="120" Margin="8,0,0,0" VerticalAlignment="Center" VerticalContentAlignment="Center" SelectionChanged="CategoryFilter_SelectionChanged"
                              ItemsSource="{Binding Categories, RelativeSource={RelativeSource AncestorType=UserControl}}"
                              DisplayMemberPath="Name"
                              SelectedValuePath="Code" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource CardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <controls:ActionButtonGroup Grid.Row="0" Title="商品列表">
                    <controls:ActionButtonGroup.BodyContent>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="新增商品" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,8,0" Click="AddProduct_Click" />
                            <Button Content="Web导入" Style="{StaticResource AccentButtonStyle}" Click="WebImport_Click" />
                        </StackPanel>
                    </controls:ActionButtonGroup.BodyContent>
                </controls:ActionButtonGroup>

                <DataGrid Grid.Row="1" x:Name="ProductGrid"
                          IsReadOnly="True"
                          ItemsSource="{Binding Products, RelativeSource={RelativeSource AncestorType=UserControl}}">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="序号" Width="80">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Seq}" HorizontalAlignment="Center" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="名称" Binding="{Binding Name}" Width="100" />
                        <DataGridTextColumn Header="分类" Binding="{Binding CategoryName}" Width="100" />
                        <DataGridTextColumn Header="单价" Binding="{Binding PriceText}" Width="100" />
                        <DataGridTextColumn Header="单位" Binding="{Binding Unit}" Width="70" />
                        <DataGridTextColumn Header="最小间隔(天)" Binding="{Binding MinIntervalDays}" Width="120" />
                        <DataGridTemplateColumn Header="状态" Width="80">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <controls:StatusBadge Text="{Binding StatusText}" Tone="{Binding StatusTone}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="更新时间" Binding="{Binding UpdatedAt}" Width="100" />
                        <DataGridTextColumn Header="" Width="20" MinWidth="10" />
                        <DataGridTemplateColumn Header="操作" Width="Auto">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="编辑" Style="{StaticResource GridActionPrimaryButtonStyle}" Width="60" Margin="0,0,6,0" Click="Edit_Click" Tag="{Binding Id}" />
                                        <Button Content="启/停" Style="{StaticResource GridActionSecondaryButtonStyle}" Width="60" Margin="0,0,6,0" Click="Toggle_Click" Tag="{Binding Id}" />
                                        <Button Content="删除" Style="{StaticResource GridActionDangerButtonStyle}" Width="60" Click="Delete_Click" Tag="{Binding Id}" />
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
