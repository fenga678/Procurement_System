<UserControl x:Class="CanteenProcurement.Wpf.Views.SystemSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="700"
             d:DesignWidth="900"
             Background="{DynamicResource Brush.Background}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 页面标题 -->
        <Border Grid.Row="0" Style="{StaticResource PageHeaderCardStyle}" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="系统设置" Style="{StaticResource PageTitleStyle}" Foreground="{DynamicResource Brush.Text.Inverse}" />
                <TextBlock Text="配置软件授权和数据库连接。" Style="{StaticResource TopHeaderSubtitleStyle}" Margin="0,8,0,0" />
            </StackPanel>
        </Border>

        <!-- 设置内容 - 左右分栏 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- 左侧：授权管理 -->
            <Border Grid.Column="0" Style="{StaticResource CardStyle}" VerticalAlignment="Top">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                    <StackPanel>
                        <TextBlock Text="授权管理" Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,16" />
                        
                        <!-- 授权状态 -->
                        <StackPanel Margin="0,0,0,16">
                            <TextBlock Text="授权状态" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,6" />
                            <TextBlock x:Name="LicenseStatusText" Text="试用版" FontSize="16" FontWeight="Bold" 
                                       Foreground="{DynamicResource Brush.Warning}" />
                        </StackPanel>
                        
                        <!-- 机器码 -->
                        <StackPanel Margin="0,0,0,16">
                            <TextBlock Text="机器码" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,6" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="200" />
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="MachineCodeText" Grid.Column="0"
                                         Text="XXXX-XXXX-XXXX-XXXX" 
                                         IsReadOnly="True"
                                         FontFamily="Consolas" FontSize="14"
                                         Padding="8,6" VerticalContentAlignment="Center"
                                         Background="{DynamicResource Brush.Surface}" />
                                <Button x:Name="CopyMachineCodeBtn" Grid.Column="1"
                                        Content="复制" Style="{StaticResource SecondaryButtonStyle}"
                                        Width="100" Margin="8,0,0,0" Click="CopyMachineCode_Click" />
                            </Grid>
                            <TextBlock Text="点击复制按钮复制机器码，用于获取注册码" 
                                       Style="{StaticResource HintTextStyle}" FontSize="11" Margin="0,4,0,0" />
                        </StackPanel>
                        
                        <!-- 注册码输入 -->
                        <StackPanel Margin="0,0,0,16">
                            <TextBlock Text="注册码" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,6" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="200" />
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="LicenseKeyText" Grid.Column="0"
                                         Style="{StaticResource DefaultTextBoxStyle}"
                                         FontFamily="Consolas" FontSize="12"
                                         TextWrapping="Wrap" AcceptsReturn="False"
                                         VerticalScrollBarVisibility="Hidden" />
                                <Button x:Name="RegisterBtn" Grid.Column="1"
                                        Content="注册" Style="{StaticResource PrimaryButtonStyle}"
                                        Width="100" Margin="8,0,0,0" Click="Register_Click" />
                            </Grid>
                        </StackPanel>
                        
                        <!-- 试用限制说明 -->
                        <Border x:Name="TrialLimitsPanel" Background="#FEF3C7" Padding="12" CornerRadius="6">
                            <StackPanel>
                                <TextBlock Text="试用版限制" FontWeight="SemiBold" Foreground="#92400E" FontSize="12" />
                                <TextBlock x:Name="TrialLimitsText" Foreground="#92400E" FontSize="11" Margin="0,6,0,0" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- 右侧：数据库配置 -->
            <Border Grid.Column="2" Style="{StaticResource CardStyle}" VerticalAlignment="Top">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                    <StackPanel>
                        <TextBlock Text="数据库配置" Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,16" />
                        
                        <!-- 数据库类型选择 -->
                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="数据库类型" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,8" />
                            <StackPanel Orientation="Horizontal">
                                <RadioButton x:Name="RbSqlite" Content="SQLite（推荐）" GroupName="DbType" IsChecked="True"
                                             VerticalAlignment="Center" Margin="0,0,20,0" Checked="DbType_Changed" />
                                <RadioButton x:Name="RbMySql" Content="MySQL" GroupName="DbType"
                                             VerticalAlignment="Center" Checked="DbType_Changed" />
                            </StackPanel>
                        </StackPanel>
                        
                        <TextBlock x:Name="DbTypeHint" Text="SQLite 无需额外配置，数据库文件自动创建。" 
                                   Style="{StaticResource HintTextStyle}" Margin="0,0,0,12" FontSize="11" TextWrapping="Wrap" />

                        <!-- SQLite 配置 -->
                        <StackPanel x:Name="SqliteConfigPanel" Visibility="Visible">
                            <Border Background="{DynamicResource Brush.Surface}" Padding="12" CornerRadius="6">
                                <StackPanel>
                                    <TextBlock Text="SQLite 配置" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,10" />
                                    
                                    <Label Content="数据库文件路径" Style="{StaticResource DefaultLabelStyle}" FontSize="11" />
                                    <TextBox x:Name="SqlitePathText" Style="{StaticResource DefaultTextBoxStyle}"
                                             Text="data/canteen.db" Margin="0,4,0,0" FontSize="12" />
                                    
                                    <TextBlock Text="✓ 零配置：自动创建数据库和表结构"
                                               Foreground="{DynamicResource Brush.Success}" Margin="0,10,0,0" FontSize="11" />
                                    <TextBlock Text="✓ 便携性：数据库文件可随程序移动"
                                               Foreground="{DynamicResource Brush.Success}" Margin="0,4,0,0" FontSize="11" />
                                    <TextBlock Text="✓ 备份简单：复制 .db 文件即可备份"
                                               Foreground="{DynamicResource Brush.Success}" Margin="0,4,0,0" FontSize="11" />
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- MySQL 配置 -->
                        <StackPanel x:Name="MySqlConfigPanel" Visibility="Collapsed">
                            <Border Background="{DynamicResource Brush.Surface}" Padding="12" CornerRadius="6">
                                <StackPanel>
                                    <TextBlock Text="MySQL 配置" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,10" />
                                    
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        
                                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,0">
                                            <Label Content="服务器" Style="{StaticResource DefaultLabelStyle}" FontSize="11" />
                                            <TextBox x:Name="DbServerText" Style="{StaticResource DefaultTextBoxStyle}"
                                                     Text="localhost" Margin="0,4,0,0" FontSize="12" />
                                        </StackPanel>
                                        
                                        <StackPanel Grid.Row="0" Grid.Column="1" Width="80">
                                            <Label Content="端口" Style="{StaticResource DefaultLabelStyle}" FontSize="11" />
                                            <TextBox x:Name="DbPortText" Style="{StaticResource DefaultTextBoxStyle}"
                                                     Text="3306" Margin="0,4,0,0" FontSize="12" />
                                        </StackPanel>
                                        
                                        <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,10,0,0">
                                            <Label Content="数据库名称" Style="{StaticResource DefaultLabelStyle}" FontSize="11" />
                                            <TextBox x:Name="DbNameText" Style="{StaticResource DefaultTextBoxStyle}"
                                                     Text="canteen_procurement" Margin="0,4,0,0" FontSize="12" />
                                        </StackPanel>
                                        
                                        <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,10,0,0">
                                            <Label Content="用户名" Style="{StaticResource DefaultLabelStyle}" FontSize="11" />
                                            <TextBox x:Name="DbUserText" Style="{StaticResource DefaultTextBoxStyle}"
                                                     Text="root" Margin="0,4,0,0" FontSize="12" />
                                        </StackPanel>
                                        
                                        <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,10,0,0">
                                            <Label Content="密码" Style="{StaticResource DefaultLabelStyle}" FontSize="11" />
                                            <PasswordBox x:Name="DbPasswordBox" Margin="0,4,0,0" FontSize="12" />
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- 操作按钮 -->
                        <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                            <Button Content="测试连接" Style="{StaticResource SecondaryButtonStyle}"
                                    Width="100" Margin="0,0,10,0" Click="TestDb_Click" />
                            <Button Content="保存配置" Style="{StaticResource PrimaryButtonStyle}"
                                    Width="100" Click="SaveDb_Click" />
                        </StackPanel>

                        <!-- 提示信息 -->
                        <Border Background="{DynamicResource Brush.Surface}" Padding="10" CornerRadius="6" Margin="0,16,0,0">
                            <StackPanel>
                                <TextBlock Text="提示" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,6" />
                                <TextBlock Text="• 配置保存后立即生效" Style="{StaticResource HintTextStyle}" FontSize="10" Margin="0,2,0,0" />
                                <TextBlock Text="• 切换数据库后需重新加载数据" Style="{StaticResource HintTextStyle}" FontSize="10" Margin="0,2,0,0" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>
