<UserControl x:Class="CanteenProcurement.Wpf.Views.TaskManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:CanteenProcurement.Wpf.Controls"


             mc:Ignorable="d"
             Background="{DynamicResource Brush.Background}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource PageHeaderCardStyle}" Margin="0,0,0,12" Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="任务管理" Style="{StaticResource PageTitleStyle}" Foreground="{DynamicResource Brush.Text.Inverse}" FontSize="18" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <TextBox Tag="Task.SearchBox" Style="{StaticResource DefaultTextBoxStyle}" Width="160" VerticalAlignment="Center"
                             ToolTip="输入年月或任务编号" TextChanged="SearchBox_TextChanged" />
                    <ComboBox Tag="Task.StatusCombo"  Width="100" Margin="8,0,0,0" VerticalAlignment="Center" VerticalContentAlignment="Center" SelectionChanged="StatusCombo_SelectionChanged" SelectedIndex="0">
                        <ComboBoxItem Content="全部" Tag="-1" IsSelected="True" />
                        <ComboBoxItem Content="待生成" Tag="0" />
                        <ComboBoxItem Content="已完成" Tag="1" />
                        <ComboBoxItem Content="已取消" Tag="2" />
                    </ComboBox>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource CardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <controls:ActionButtonGroup Grid.Row="0" Title="任务列表">
                    <controls:ActionButtonGroup.BodyContent>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="新建任务" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,8,0" Click="btnCreateTask_Click" />
                            <Button Content="导出明细" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0" Click="btnExportExcel_Click" />
                            <Button Content="清空数据" Style="{StaticResource SecondaryButtonStyle}" Click="ClearData_Click" />
                        </StackPanel>
                    </controls:ActionButtonGroup.BodyContent>
                </controls:ActionButtonGroup>

                <DataGrid Grid.Row="1"
                          Margin="0,16,0,0"
                          x:Name="dgTasks"
                          ItemsSource="{Binding Tasks}"
                          SelectionMode="Extended"
                          SelectedItem="{Binding SelectedTask}">
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow" BasedOn="{StaticResource DataGridRowStyle}">
                            <EventSetter Event="MouseDoubleClick" Handler="dgTasks_MouseDoubleClick" />
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="任务编号" Binding="{Binding Id}" Width="100" />
                        <DataGridTextColumn Header="年月" Binding="{Binding YearMonth}" Width="100" />
                        <DataGridTextColumn Header="总预算" Binding="{Binding TotalBudget, StringFormat='￥#,##0.00'}" Width="110" />
                        <DataGridTextColumn Header="波动率" Binding="{Binding FloatRate, StringFormat='P1'}" Width="90" />

                        <!-- 状态列：固定宽度，不再自适应拉长 -->
                        <DataGridTemplateColumn Header="状态" Width="80">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <controls:StatusBadge Text="{Binding StatusDescription}" Tone="{Binding StatusTone}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="生成时间" Binding="{Binding GeneratedAt, StringFormat='yyyy-MM-dd HH:mm'}" Width="150" />
                        <DataGridTextColumn Header="创建人" Binding="{Binding CreatedBy}" Width="100" />
                        <DataGridTextColumn Header="创建时间" Binding="{Binding CreatedAt, StringFormat='yyyy-MM-dd HH:mm'}" Width="150" />

                        <!-- 空白占位列：保留，但更精简 -->
                        <DataGridTextColumn Header="" Width="20" MinWidth="10" />
                        <DataGridTemplateColumn Header="操作" Width="Auto">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="{Binding GenerateActionText}" Style="{StaticResource GridActionPrimaryButtonStyle}" Width="70" Margin="0,0,6,0" Click="btnGenerate_Click" />
                                        <Button Content="查看" Style="{StaticResource GridActionSecondaryButtonStyle}" Width="55" Margin="0,0,6,0" Click="btnView_Click" />
                                        <Button Content="删除" Style="{StaticResource GridActionDangerButtonStyle}" Width="55" Click="btnDelete_Click" />
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
