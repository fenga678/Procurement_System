                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <sys:Double x:Key="ControlHeight.Small">28</sys:Double>
    <sys:Double x:Key="ControlHeight.Default">38</sys:Double>
    <sys:Double x:Key="ControlHeight.Large">44</sys:Double>

    <sys:Double x:Key="ControlWidth.Small">72</sys:Double>
    <sys:Double x:Key="ControlWidth.Medium">90</sys:Double>
    <sys:Double x:Key="ControlWidth.Large">120</sys:Double>
    <sys:Double x:Key="DialogWidth.Medium">520</sys:Double>
    <sys:Double x:Key="DialogWidth.Large">760</sys:Double>
