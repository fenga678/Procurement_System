    <Thickness x:Key="Space.FieldGap">0,0,12,12</Thickness>
    <Thickness x:Key="Space.StackGap">0,12,0,0</Thickness>
    <Thickness x:Key="Space.SmallGap">0,8,0,0</Thickness>
