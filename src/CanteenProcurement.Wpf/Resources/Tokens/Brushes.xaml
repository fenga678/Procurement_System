<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="Brush.Primary" Color="{DynamicResource Color.Brand.Primary.500}" />
    <SolidColorBrush x:Key="Brush.Primary.Hover" Color="{DynamicResource Color.Brand.Primary.600}" />
    <SolidColorBrush x:Key="Brush.Primary.Pressed" Color="{DynamicResource Color.Brand.Primary.700}" />
    <SolidColorBrush x:Key="Brush.Primary.Subtle" Color="{DynamicResource Color.Brand.Primary.100}" />

    <SolidColorBrush x:Key="Brush.Secondary" Color="{DynamicResource Color.Brand.Secondary.900}" />
    <SolidColorBrush x:Key="Brush.Secondary.Hover" Color="{DynamicResource Color.Brand.Secondary.700}" />
    <SolidColorBrush x:Key="Brush.Secondary.Subtle" Color="{DynamicResource Color.Brand.Secondary.100}" />

    <SolidColorBrush x:Key="Brush.Accent" Color="{DynamicResource Color.Status.Info}" />
    <SolidColorBrush x:Key="Brush.Accent.Subtle" Color="{DynamicResource Color.Status.Info.Subtle}" />

    <SolidColorBrush x:Key="Brush.Background" Color="{DynamicResource Color.Surface.Canvas}" />
    <SolidColorBrush x:Key="Brush.Surface" Color="{DynamicResource Color.Surface.Default}" />
    <SolidColorBrush x:Key="Brush.Surface.Subtle" Color="{DynamicResource Color.Surface.Subtle}" />
    <SolidColorBrush x:Key="Brush.Surface.Hover" Color="{DynamicResource Color.Surface.Hover}" />
    <SolidColorBrush x:Key="Brush.Surface.Disabled" Color="{DynamicResource Color.Surface.Disabled}" />

    <SolidColorBrush x:Key="Brush.Text.Primary" Color="{DynamicResource Color.Text.Primary}" />
    <SolidColorBrush x:Key="Brush.Text.Secondary" Color="{DynamicResource Color.Text.Secondary}" />
    <SolidColorBrush x:Key="Brush.Text.Muted" Color="{DynamicResource Color.Text.Muted}" />
    <SolidColorBrush x:Key="Brush.Text.Inverse" Color="{DynamicResource Color.Text.Inverse}" />

    <SolidColorBrush x:Key="Brush.Border" Color="{DynamicResource Color.Border.Default}" />
    <SolidColorBrush x:Key="Brush.Border.Strong" Color="{DynamicResource Color.Border.Strong}" />
    <SolidColorBrush x:Key="Brush.Divider" Color="{DynamicResource Color.Border.Divider}" />

    <SolidColorBrush x:Key="Brush.Success" Color="{DynamicResource Color.Status.Success}" />
    <SolidColorBrush x:Key="Brush.Success.Subtle" Color="{DynamicResource Color.Status.Success.Subtle}" />
    <SolidColorBrush x:Key="Brush.Warning" Color="{DynamicResource Color.Status.Warning}" />
    <SolidColorBrush x:Key="Brush.Warning.Subtle" Color="{DynamicResource Color.Status.Warning.Subtle}" />
    <SolidColorBrush x:Key="Brush.Danger" Color="{DynamicResource Color.Status.Danger}" />
    <SolidColorBrush x:Key="Brush.Danger.Hover" Color="{DynamicResource Color.Status.Danger.Hover}" />
    <SolidColorBrush x:Key="Brush.Danger.Subtle" Color="{DynamicResource Color.Status.Danger.Subtle}" />
    <SolidColorBrush x:Key="Brush.Info" Color="{DynamicResource Color.Status.Info}" />
    <SolidColorBrush x:Key="Brush.Info.Subtle" Color="{DynamicResource Color.Status.Info.Subtle}" />
    <SolidColorBrush x:Key="Brush.Overlay" Color="#660F2940" />
    <SolidColorBrush x:Key="Brush.Nav.Active" Color="#26FFFFFF" />
    <SolidColorBrush x:Key="Brush.Nav.Hover" Color="#1AFFFFFF" />
    <SolidColorBrush x:Key="Brush.Nav.Pressed" Color="#30FFFFFF" />

    <SolidColorBrush x:Key="PrimaryBrush" Color="{DynamicResource PrimaryColor}" />

    <SolidColorBrush x:Key="SecondaryBrush" Color="{DynamicResource SecondaryColor}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{DynamicResource AccentColor}" />
    <SolidColorBrush x:Key="BackgroundBrush" Color="{DynamicResource BackgroundColor}" />
    <SolidColorBrush x:Key="TextBrush" Color="{DynamicResource TextColor}" />
    <SolidColorBrush x:Key="SuccessBrush" Color="{DynamicResource SuccessColor}" />
    <SolidColorBrush x:Key="WarningBrush" Color="{DynamicResource WarningColor}" />
</ResourceDictionary>
