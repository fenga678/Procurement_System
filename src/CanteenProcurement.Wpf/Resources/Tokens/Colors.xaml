    <Color x:Key="Color.Status.Danger.Subtle">#FDE8E6</Color>
    <Color x:Key="Color.Status.Info">#00BCD4</Color>
    <Color x:Key="Color.Status.Info.Subtle">#D9F7FB</Color>

    <Color x:Key="PrimaryColor">#1E88E5</Color>
    <Color x:Key="SecondaryColor">#0F2940</Color>
    <Color x:Key="AccentColor">#00BCD4</Color>
    <Color x:Key="BackgroundColor">#F4F7FB</Color>
