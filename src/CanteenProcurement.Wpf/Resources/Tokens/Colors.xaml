<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="Color.Brand.Primary.700">#0F5CB8</Color>
    <Color x:Key="Color.Brand.Primary.600">#1565C0</Color>
    <Color x:Key="Color.Brand.Primary.500">#1E88E5</Color>
    <Color x:Key="Color.Brand.Primary.100">#D9ECFF</Color>

    <Color x:Key="Color.Brand.Secondary.900">#0F2940</Color>
    <Color x:Key="Color.Brand.Secondary.700">#163657</Color>
    <Color x:Key="Color.Brand.Secondary.100">#E5EEF7</Color>

    <Color x:Key="Color.Surface.Canvas">#F4F7FB</Color>
    <Color x:Key="Color.Surface.Default">#FFFFFF</Color>
    <Color x:Key="Color.Surface.Subtle">#EEF3F8</Color>
    <Color x:Key="Color.Surface.Hover">#F8FBFF</Color>
    <Color x:Key="Color.Surface.Disabled">#F3F5F7</Color>

    <Color x:Key="Color.Text.Primary">#1A2B3C</Color>
    <Color x:Key="Color.Text.Secondary">#425466</Color>
    <Color x:Key="Color.Text.Muted">#6B7A90</Color>
    <Color x:Key="Color.Text.Inverse">#FFFFFF</Color>

