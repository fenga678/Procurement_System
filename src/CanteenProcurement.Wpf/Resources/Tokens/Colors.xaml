    <Color x:Key="Color.Border.Divider">#E0E7EF</Color>

    <Color x:Key="Color.Status.Success">#1FAA89</Color>
    <Color x:Key="Color.Status.Success.Subtle">#DFF7F0</Color>
    <Color x:Key="Color.Status.Warning">#F5A524</Color>
