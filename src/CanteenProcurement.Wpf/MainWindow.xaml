<Window x:Class="CanteenProcurement.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:CanteenProcurement.Wpf.Controls"
        mc:Ignorable="d"
        Title="食堂物料预采购管理系统"
        Height="820"
        Width="1360"
        MinHeight="760"
        MinWidth="1240"
        Style="{StaticResource AppWindowStyle}">
    <Grid Margin="{DynamicResource Space.PagePadding}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <controls:TopHeader Grid.Row="0"
                            Margin="0,0,0,20"
                            Title="食堂物料预采购管理系统"
                            Subtitle="统一预算拆分、分类调度与采购执行的桌面工作台"
                            MetaTitle="v1.2.0"
                            MetaSubtitle="{Binding LicenseStatus, RelativeSource={RelativeSource AncestorType=Window}}" />

        <Border Grid.Row="1" Style="{StaticResource ShellSurfaceStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="260" />
                    <ColumnDefinition Width="1" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="{DynamicResource Brush.Secondary}" CornerRadius="20,0,0,20" Padding="20">
                    <controls:SidebarNav x:Name="sidebarNav" SectionSelected="SidebarNav_SectionSelected" />
                </Border>

                <Border Grid.Column="1" Background="{DynamicResource Brush.Divider}" />

                <Border Grid.Column="2" Background="{DynamicResource Brush.Background}" Padding="20" CornerRadius="0,20,20,0">
                    <ContentControl x:Name="mainContent" />
                </Border>
            </Grid>
        </Border>

        <controls:ToastHost x:Name="toastHost"
                            Grid.RowSpan="2"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Margin="0,24,16,0" />
        <controls:LoadingOverlay x:Name="loadingOverlay" Grid.RowSpan="2" />
    </Grid>
</Window>
