using System;
using System.Windows;
using CommunityToolkit.Mvvm.DependencyInjection;
using OfficeOpenXml;
using SQLitePCL;
using CanteenProcurementSystem.DAL;
using CanteenProcurementSystem.ViewModels;

namespace CanteenProcurementSystem
{
    public partial class App : Application
    {
        private ProductManagementViewModel? _productManagementViewModel;
        private CategoryConfigViewModel? _categoryConfigViewModel;
        private ProcurementTaskViewModel? _procurementTaskViewModel;
        private ProcurementPlanViewModel? _procurementPlanViewModel;
        private MainViewModel? _mainViewModel;

        protected override void OnStartup(StartupEventArgs e)
        {
            base.OnStartup(e);

            // initialize native sqlite bundle
            Batteries_V2.Init();

            ExcelPackage.License.SetNonCommercialPersonal("CanteenProcurementSystem");

            // ensure DB file exists
            DatabaseHelper.InitializeDatabase();

            // If schema missing, ask user to create
            if (!DatabaseHelper.SchemaExists())
            {
                var result = MessageBox.Show(
                    "数据库表尚未创建，是否现在创建？（取消将继续运行，但部分功能可能不可用）",
                    "创建数据库表",
                    MessageBoxButton.YesNo,
                    MessageBoxImage.Question);

                if (result == MessageBoxResult.Yes)
                {
                    try
                    {
                        DatabaseHelper.EnsureSchemaAndSeed();
                    }
                    catch (Exception ex)
                    {
                        MessageBox.Show($"创建数据库表失败：{ex.Message}", "错误", MessageBoxButton.OK, MessageBoxImage.Error);
                    }
                }
            }

            InitializeViewModels();

            var mainWindow = new MainWindow(
                _mainViewModel!,
                _productManagementViewModel!,
                _categoryConfigViewModel!,
                _procurementTaskViewModel!,
                _procurementPlanViewModel!);

            mainWindow.Show();
        }

        private void InitializeViewModels()
        {
            _productManagementViewModel = new ProductManagementViewModel();
            _categoryConfigViewModel = new CategoryConfigViewModel();
            _procurementTaskViewModel = new ProcurementTaskViewModel();
            _procurementPlanViewModel = new ProcurementPlanViewModel();
            _mainViewModel = new MainViewModel(
                _productManagementViewModel,
                _categoryConfigViewModel,
                _procurementTaskViewModel,
                _procurementPlanViewModel);
        }
    }
}
