using System;
using System.Collections.Generic;
using System.Linq;
using System.Threading.Tasks;
using System.Windows;
using System.Windows.Controls;
using CanteenProcurementSystem.Models;

namespace CanteenProcurementSystem.Views
{
    public partial class ProductManagementView : UserControl
    {
        private async void OnBulkImportClick(object sender, RoutedEventArgs e)
        {
            var vm = this.DataContext;
            IEnumerable<Category> categories = Enumerable.Empty<Category>();
n            try
            {
                dynamic dyn = vm;
                categories = (IEnumerable<Category>)(dyn.Categories ?? Enumerable.Empty<Category>());
            }
            catch
            {
                // ignore
            }
n            var win = new ImportProductsWindow(categories, products =>
            {
                try
                {
                    dynamic dynVm = vm;
                    var result = dynVm.ImportProductsAsync(products);
                    if (result is Task t)
                    {
                        t.GetAwaiter().GetResult();
                    }
                }
                catch (Exception ex)
                {
                    MessageBox.Show($"导入回调执行失败，请在 ViewModel 中实现 ImportProductsAsync。详细：{ex.Message}", "错误", MessageBoxButton.OK, MessageBoxImage.Error);
                }
            });
n            win.Owner = Window.GetWindow(this);
            win.ShowDialog();
        }
    }
}
