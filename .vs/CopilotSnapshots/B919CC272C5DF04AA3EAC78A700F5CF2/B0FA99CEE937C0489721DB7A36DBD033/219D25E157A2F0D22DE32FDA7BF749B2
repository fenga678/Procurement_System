using Dapper;
using System.Data.SQLite;
using CanteenProcurementSystem.Models;

namespace CanteenProcurementSystem.DAL;

public class ProductRepository : IRepository<Product>
{
    private readonly string _connectionString;

    public ProductRepository()
    {
        _connectionString = DatabaseHelper.GetConnectionString();
    }

    public async Task<IEnumerable<Product>> GetAllAsync()
    {
        using var conn = new SQLiteConnection(_connectionString);
        const string sql = "SELECT * FROM products ORDER BY id";
        return await conn.QueryAsync<Product>(sql);
    }

    public async Task<Product?> GetByIdAsync(int id)
    {
        using var conn = new SQLiteConnection(_connectionString);
        const string sql = "SELECT * FROM products WHERE id = @Id";
        return await conn.QueryFirstOrDefaultAsync<Product>(sql, new { Id = id });
    }

    public async Task<int> AddAsync(Product entity)
    {
        using var conn = new SQLiteConnection(_connectionString);
        const string sql = @"
            INSERT INTO products (name, category_code, price, unit, min_interval_days, remark, status, created_at, updated_at)
            VALUES (@Name, @CategoryCode, @Price, @Unit, @MinIntervalDays, @Remark, @Status, @CreatedAt, @UpdatedAt);
            SELECT last_insert_rowid();";
        return await conn.ExecuteScalarAsync<int>(sql, entity);
    }

    public async Task<bool> UpdateAsync(Product entity)
    {
        using var conn = new SQLiteConnection(_connectionString);
        const string sql = @"
            UPDATE products 
            SET name = @Name, category_code = @CategoryCode, price = @Price, unit = @Unit, 
                min_interval_days = @MinIntervalDays, remark = @Remark, status = @Status, updated_at = @UpdatedAt
            WHERE id = @Id";
        var result = await conn.ExecuteAsync(sql, entity);
        return result > 0;
    }

    public async Task<bool> DeleteAsync(int id)
    {
        using var conn = new SQLiteConnection(_connectionString);
        const string sql = "DELETE FROM products WHERE id = @Id";
        var result = await conn.ExecuteAsync(sql, new { Id = id });
        return result > 0;
    }
}
