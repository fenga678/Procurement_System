using Dapper;
using System.Data.SQLite;
using CanteenProcurementSystem.Models;

namespace CanteenProcurementSystem.DAL;

public class TaskCategoryBudgetRepository : IRepository<TaskCategoryBudget>
{
    private readonly string _connectionString;

    public TaskCategoryBudgetRepository()
    {
        _connectionString = DatabaseHelper.GetConnectionString();
    }

    public async Task<IEnumerable<TaskCategoryBudget>> GetAllAsync()
    {
        using var conn = new SQLiteConnection(_connectionString);
        const string sql = "SELECT * FROM task_category_budgets ORDER BY id";
        return await conn.QueryAsync<TaskCategoryBudget>(sql);
    }

    public async Task<TaskCategoryBudget?> GetByIdAsync(int id)
    {
        using var conn = new SQLiteConnection(_connectionString);
        const string sql = "SELECT * FROM task_category_budgets WHERE id = @Id";
        return await conn.QueryFirstOrDefaultAsync<TaskCategoryBudget>(sql, new { Id = id });
    }

    public async Task<IEnumerable<TaskCategoryBudget>> GetByTaskIdAsync(int taskId)
    {
        using var conn = new SQLiteConnection(_connectionString);
        const string sql = "SELECT * FROM task_category_budgets WHERE task_id = @TaskId";
        return await conn.QueryAsync<TaskCategoryBudget>(sql, new { TaskId = taskId });
    }

    public async Task<int> AddAsync(TaskCategoryBudget entity)
    {
        using var conn = new SQLiteConnection(_connectionString);
        const string sql = @"
            INSERT INTO task_category_budgets (task_id, category_code, ratio, budget, frequency_days, occurrence_count, daily_budget, created_at)
            VALUES (@TaskId, @CategoryCode, @Ratio, @Budget, @FrequencyDays, @OccurrenceCount, @DailyBudget, @CreatedAt);
            SELECT last_insert_rowid();";
        return await conn.ExecuteScalarAsync<int>(sql, entity);
    }

    public async Task AddRangeAsync(IEnumerable<TaskCategoryBudget> entities)
    {
        using var conn = new SQLiteConnection(_connectionString);
        const string sql = @"
            INSERT INTO task_category_budgets (task_id, category_code, ratio, budget, frequency_days, occurrence_count, daily_budget, created_at)
            VALUES (@TaskId, @CategoryCode, @Ratio, @Budget, @FrequencyDays, @OccurrenceCount, @DailyBudget, @CreatedAt);";
        await conn.ExecuteAsync(sql, entities);
    }

    public async Task<bool> DeleteByTaskIdAsync(int taskId)
    {
        using var conn = new SQLiteConnection(_connectionString);
        const string sql = "DELETE FROM task_category_budgets WHERE task_id = @TaskId";
        var result = await conn.ExecuteAsync(sql, new { TaskId = taskId });
        return result > 0;
    }

    public async Task<bool> UpdateAsync(TaskCategoryBudget entity)
    {
        using var conn = new SQLiteConnection(_connectionString);
        const string sql = @"
            UPDATE task_category_budgets 
            SET task_id = @TaskId, category_code = @CategoryCode, ratio = @Ratio, budget = @Budget, 
                frequency_days = @FrequencyDays, occurrence_count = @OccurrenceCount, daily_budget = @DailyBudget
            WHERE id = @Id";
        var result = await conn.ExecuteAsync(sql, entity);
        return result > 0;
    }

    public async Task<bool> DeleteAsync(int id)
    {
        using var conn = new SQLiteConnection(_connectionString);
        const string sql = "DELETE FROM task_category_budgets WHERE id = @Id";
        var result = await conn.ExecuteAsync(sql, new { Id = id });
        return result > 0;
    }
}
